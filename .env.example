# On DOCC (puff), these are loaded from Vault KV v2 mount secret-versioned at path
# solutions/slack-grammar-bot/puff (see docc/manifest.json). Populate with:
#   cp docc/vault-puff-secrets.example.json docc/vault-puff-secrets.json
#   # edit docc/vault-puff-secrets.json, then:
#   vault kv put -mount=secret-versioned solutions/slack-grammar-bot/puff @docc/vault-puff-secrets.json

# Slack Socket Mode:
# - SLACK_APP_TOKEN starts with xapp- and needs connections:write.
# - SLACK_BOT_TOKEN starts with xoxb- and needs commands (and usually chat:write).
SLACK_APP_TOKEN=xapp-your_slack_app_token
SLACK_BOT_TOKEN=xoxb-your_slack_bot_token

INFERENCE_HUB_MODEL_ACCESS_KEY=your_digitalocean_model_access_key
# Or use MODEL_ACCESS_KEY instead of INFERENCE_HUB_MODEL_ACCESS_KEY (same value)
INFERENCE_HUB_DEFAULT_AGENT=openai/gpt-4o-mini
SLACK_COMMAND_NAME=/grammar
# Delayed reply only: ephemeral (default) or in_channel (posts to channel; visible in shared history).
# SLACK_REPLY_VISIBILITY=in_channel
# GenAI Agent host (recommended if you do not use serverless Inference Hub): path must be /api/v1 — requests go to {BASE_URL}/chat/completions
# INFERENCE_HUB_BASE_URL=https://YOUR_AGENT_SUBDOMAIN.agents.do-ai.run/api/v1
# Serverless default if unset: https://inference.do-ai.run/v1
# INFERENCE_HUB_SYSTEM_PROMPT=You are a helpful assistant for a Slack workspace. Keep responses concise and actionable.
