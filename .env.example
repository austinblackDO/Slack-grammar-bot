# On DOCC (puff), these are loaded from Vault KV v2 mount secret-versioned at path
# dogfish/slack-grammar-bot/puff (see docc/manifest.json). Populate with:
#   cp docc/vault-puff-secrets.example.json docc/vault-puff-secrets.json
#   # edit docc/vault-puff-secrets.json, then:
#   vault kv put -mount=secret-versioned dogfish/slack-grammar-bot/puff @docc/vault-puff-secrets.json
SLACK_SIGNING_SECRET=your_slack_signing_secret
INFERENCE_HUB_MODEL_ACCESS_KEY=your_digitalocean_model_access_key
# Or use MODEL_ACCESS_KEY instead of INFERENCE_HUB_MODEL_ACCESS_KEY (same value)
INFERENCE_HUB_DEFAULT_AGENT=openai/gpt-4o-mini
SLACK_COMMAND_NAME=/grammar
# Delayed reply only: ephemeral (default) or in_channel (posts to channel; visible in shared history).
# SLACK_REPLY_VISIBILITY=in_channel
# Optional
# INFERENCE_HUB_BASE_URL=https://inference.do-ai.run/v1
# GenAI Agent deployments: use .../api/v1 (POST .../api/v1/chat/completions), Bearer = agent key.
# INFERENCE_HUB_BASE_URL=https://YOUR_AGENT.agents.do-ai.run/api/v1
# INFERENCE_HUB_SYSTEM_PROMPT=You are a helpful assistant for a Slack workspace. Keep responses concise and actionable.
